#include<stdio.h>
int main()
{
    int n,a1=0,a2=1,next;
    printf("enter the number of terms:");
    scanf("%d",&n);
    printf("Fibonacci series: %d %d",a1,a2);
    for(int i=3;i<=n;i++){
        next=a1+a2;
        printf("%d",next);
        a1=a2;
        a2=next;
    }
    return 0;
}



